---
// Topbar component
// 共用：跨所有頁面，nav 連結來自 nav.json
// pathPrefix：主頁傳 ''、子頁（profiles/services）傳 '../'
import site from '../data/site.json';
import nav from '../data/nav.json';

interface Props {
  pathPrefix?: string;
}
const { pathPrefix = '' } = Astro.props;
---

<header class="topbar">
  <div class="inner">
    <a class="brand" href={`${pathPrefix}index.html`} aria-label="回首頁">
      <span class="mark">永</span>{site.brand_short}
    </a>
    <button class="nav-toggle" aria-label="開啟選單" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <nav>
      {nav.main.map((item) => (
        <a href={`${pathPrefix}${item.href}`}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
