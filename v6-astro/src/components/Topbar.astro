---
// Topbar component
// 共用：跨所有頁面，nav 連結來自 nav.json
import site from '../data/site.json';
import nav from '../data/nav.json';
---

<header class="topbar">
  <div class="inner">
    <a class="brand" href="index.html" aria-label="回首頁">
      <span class="mark">永</span>{site.brand_short}
    </a>
    <button class="nav-toggle" aria-label="開啟選單" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <nav>
      {nav.main.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
