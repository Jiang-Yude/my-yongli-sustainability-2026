---
// BaseLayout：跨所有頁面共用的 head + topbar + footer 殼
// pathPrefix：主頁傳 ''（預設）、子頁（profiles/services）傳 '../'
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  pathPrefix?: string;
  extraGoogleFontWeights?: boolean;  // index.html 用了 700 + Inter，預設 false 只載 400-600
}

const { title, description, pathPrefix = '', extraGoogleFontWeights = false } = Astro.props;

const cssHref = `${pathPrefix}assets/css/common.css?v=8`;

// Google Fonts URL：index 含 700 + Inter，其他頁用較精簡的字重
const fontsUrl = extraGoogleFontWeights
  ? 'https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&family=Noto+Serif+TC:wght@500;600;700&family=Inter:wght@400;500;600&display=swap'
  : 'https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&family=Noto+Serif+TC:wght@500;600;700&display=swap';
---

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
{description && <meta name="description" content={description} />}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href={fontsUrl} rel="stylesheet">
<link rel="stylesheet" href={cssHref}>
<slot name="extra-head" />
</head>
<body>

<Topbar pathPrefix={pathPrefix} />

<slot />

<Footer pathPrefix={pathPrefix} />

</body>
</html>
